{
  "name": "transvd",
  "version": "2.0.1",
  "packageManager": "bun@1.3.14",
  "description": "Desktop video editor powered by ffmpeg.wasm — Tauri 2.x port of ffmpeg-webCLI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
