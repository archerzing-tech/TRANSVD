{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2/main/schema/tauri.conf.json",
  "productName": "TRANSVD",
  "version": "2.2.0",
  "identifier": "com.transvd.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "TRANSVD",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "./Entitlements.plist",
      "signingIdentity": "-"
    },
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    },
    "android": {
      "minSdkVersion": 29
    }
  }
}
